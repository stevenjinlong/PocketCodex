{
  "name": "pocket-codex",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:packages && npm run build:apps",
    "build:packages": "npm run build --workspace @pocket-codex/protocol --workspace @pocket-codex/crypto --workspace @pocket-codex/db",
    "build:apps": "npm run build --workspace @pocket-codex/gateway --workspace @pocket-codex/agent --workspace @pocket-codex/web",
    "stack:up": "docker compose up --build",
    "stack:up:postgres": "POCKET_CODEX_STORAGE_BACKEND=postgres DATABASE_URL=postgres://pocket_codex:pocket_codex@postgres:5432/pocket_codex docker compose --profile postgres up --build",
    "stack:down": "docker compose down",
    "stack:logs": "docker compose logs -f web gateway postgres",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "docker compose down -v",
    "dev:web": "npm run dev --workspace @pocket-codex/web",
    "dev:gateway": "npm run dev --workspace @pocket-codex/gateway",
    "dev:agent": "npm run dev --workspace @pocket-codex/agent",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
