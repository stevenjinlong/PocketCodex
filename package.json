{
  "name": "pocket-codex",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:packages && npm run build:apps",
    "build:packages": "npm run build --workspace @pocket-codex/protocol --workspace @pocket-codex/crypto --workspace @pocket-codex/db",
    "build:apps": "npm run build --workspace @pocket-codex/gateway --workspace @pocket-codex/agent --workspace @pocket-codex/web",
    "dev:web": "npm run dev --workspace @pocket-codex/web",
    "dev:gateway": "npm run dev --workspace @pocket-codex/gateway",
    "dev:agent": "npm run dev --workspace @pocket-codex/agent",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
